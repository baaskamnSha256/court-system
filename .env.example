APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# 419 Page Expired: APP_URL нь хөтчийн хаягтай ЯГ АДИЛHAN байх ёстой.
# localhost болон 127.0.0.1, court-system.test гэж хольж бүү ашигла.
# Laragon: APP_URL=http://court-system.test эсвэл http://127.0.0.1:8000 (аль нэгийг л)
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Local-д file ашиглавал sessions хүснэгт шаардлагагүй. database бол php artisan session:table + migrate.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Иргэний регистрийн дугаараар хайлт (хурлын зар товлох, XYP гэх мэт гадаад REST).
# Хоосон бол хуудас дээр туршилтын өгөгдөл харагдана.
DEFENDANT_SEARCH_API_URL=
# rest (default) эсвэл soap
DEFENDANT_SEARCH_API_PROTOCOL=rest
# GET (анхны) эсвэл POST
DEFENDANT_SEARCH_API_METHOD=GET
DEFENDANT_SEARCH_API_TOKEN=
# REST-д Bearer ашиглах бол Authorization, SOAP XYP-д accessToken
DEFENDANT_SEARCH_API_TOKEN_HEADER=Authorization
DEFENDANT_SEARCH_API_TIMEOUT=15
# Холболт тогтоох хугацаа (сек). 0 = Guzzle/cURL default. XYP-д удаан бол 20–30 туршина уу.
DEFENDANT_SEARCH_API_CONNECT_TIMEOUT=0
# Зарим сервер IPv6-оор xyp.gov.mn руу хүрэхгүй бол true (зөвхөн IPv4)
DEFENDANT_SEARCH_API_FORCE_IPV4=false
# GET үед query нэр
DEFENDANT_SEARCH_API_QUERY_PARAM=registry
# POST үед JSON — {registry} нь бодит регистрийн дугаар болно
DEFENDANT_SEARCH_API_POST_BODY={"registry":"{registry}"}
# SOAP үед action ихэвчлэн хоосон байдаг
DEFENDANT_SEARCH_API_SOAP_ACTION=
# SOAP method (ж: WS100101_getCitizenIDCardInfo)
DEFENDANT_SEARCH_API_SOAP_METHOD=
# SOAP method доторх request XML (ж: <request><regnum>{registry}</regnum></request>)
DEFENDANT_SEARCH_API_SOAP_REQUEST=<request><regnum>{registry}</regnum></request>
# SOAP хүсэлтэд нэмэх timestamp header (хоосон бол нэмэхгүй)
DEFENDANT_SEARCH_API_TIMESTAMP_HEADER=timeStamp
# Хэрэв тогтмол утга хэрэгтэй бол бөглөнө, хоосон бол одоогийн epoch milliseconds илгээнэ
DEFENDANT_SEARCH_API_TIMESTAMP_VALUE=
# SOAP хүсэлтэд нэмэх signature header (ҮДТ/ESIGN-оос авсан утга)
DEFENDANT_SEARCH_API_SIGNATURE_HEADER=signature
DEFENDANT_SEARCH_API_SIGNATURE_VALUE=
# XYP key.key файлын зам (signature header-ийг accessToken.timeStamp-оос сервер дээр үүсгэх бол)
DEFENDANT_SEARCH_API_XYP_KEY_PATH=
# mTLS PFX тохиргоо
DEFENDANT_SEARCH_API_CERT_TYPE=P12
DEFENDANT_SEARCH_API_CERT_PATH=
DEFENDANT_SEARCH_API_CERT_PASSPHRASE=
# Windows schannel revocation check асуудалтай орчинд 1 болгоно
DEFENDANT_SEARCH_API_SSL_NO_REVOKE=false
# TLS verify (local оношлогоонд түр false болгож болно)
DEFENDANT_SEARCH_API_VERIFY=true
# cURL error 60 "unsuitable certificate purpose": ихэвчлэн (1) P12 нь TLS client auth-д биш,
# эсвэл (2) серверийн гинж системийн CA-тай таарахгүй. Түр VERIFY=false эсвэл CA bundle туршина.
# CA bundle файл (шаардлагатай орчинд)
DEFENDANT_SEARCH_API_CA_BUNDLE=
# Нэмэлт header-үүд JSON объектоор (ж: {"X-Request-Id":"court"})
DEFENDANT_SEARCH_API_HEADERS=

# Мэдэгдэл илгээх API (Emongolia / notification.mn)
# Идэвхжүүлэхийн өмнө USERNAME/PASSWORD/ACCESS_TOKEN-оо бөглөнө үү.
NOTIFICATION_ENABLED=false
NOTIFICATION_ACCESS_TOKEN=
NOTIFICATION_TOKEN_URL=https://notification.mn/api/v1/external/token
NOTIFICATION_NOTIFY_URL=https://notification.mn/api/v1/notification
NOTIFICATION_USERNAME=
NOTIFICATION_PASSWORD=
NOTIFICATION_TIMEOUT=15
# true: хурал үүсгэх/шинэчлэх хүсэлтийн дотор notification.mn руу шууд илгээнэ (queue worker хүлээгээгүй бол хэдэн цагийн дараа очихоос сэргийлнэ)
NOTIFICATION_DISPATCH_SYNC=false
# Queue (хоосон бол QUEUE_CONNECTION-ийг анхдагчаар ашиглана; шууд илгээх өөр сонголт: NOTIFICATION_QUEUE_CONNECTION=sync)
NOTIFICATION_QUEUE_CONNECTION=
NOTIFICATION_QUEUE_NAME=
